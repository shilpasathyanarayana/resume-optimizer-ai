# ==============================================================================
# APPLICATION
# ==============================================================================

# Environment name — controls behaviour across the app
# Values: development | staging | production
APP_ENV='development'

# Secret key used for signing JWT tokens and session cookies
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  Never reuse the same key across environments
SECRET_KEY='Your Secret key'

# How long an access token stays valid (in minutes)
# Recommended: 30 for production, 1440 (24h) for development
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ==============================================================================
# DATABASE (MySQL)
# ==============================================================================

# Hostname of your database server
# Local dev:      localhost
# Docker Compose: db  (the service name)
# Production:     your RDS / Cloud SQL hostname
DB_HOST='localhost'

# MySQL default port — change only if your server runs on a custom port
DB_PORT=3306

# Name of the database to connect to
# Create it with: CREATE DATABASE resume_optimizer;
DB_NAME='resume_optimizer'

# Database user
# Local dev:   root  (or a dedicated user)
# Production:  create a least-privilege user — never use root
DB_USER='userName'

# Password for the database user above
DB_PASSWORD='Your Password'

# Full SQLAlchemy connection string — assembled from the values above
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<dbname>
# Example: mysql+pymysql://root:password@localhost:3306/resume_optimizer
# Docker:  mysql+pymysql://root:password@db:3306/resume_optimizer
DATABASE_URL='mysql+pymysql://userName:Your Password@localhost:3306/resume_optimizer'


# ==============================================================================
# EMAIL  (Mailtrap for development)
# ==============================================================================

# Mailtrap is a safe email sandbox — emails are captured and never delivered.
# Sign up free at: https://mailtrap.io
# Get credentials:  https://mailtrap.io/inboxes → your inbox → SMTP Settings
#                   Select "Django" or "Other" from the dropdown to see values

# SMTP username shown in Mailtrap → SMTP Settings
MAIL_USERNAME='MailTrap Username'

# SMTP password shown in Mailtrap → SMTP Settings
MAIL_PASSWORD='Password'

# The "From" address that appears in sent emails
# Can be anything for Mailtrap (e.g. noreply@resume-optimizer.com)
MAIL_FROM='noreply@yourapp.com'

# Mailtrap SMTP server — do not change for sandbox
# Production: swap with your real SMTP host (e.g. smtp.sendgrid.net)
MAIL_SERVER=sandbox.smtp.mailtrap.io

# Mailtrap sandbox port — alternatives: 25, 465, 2525
# Production: 587 (TLS) or 465 (SSL)
MAIL_PORT=587


# ==============================================================================
# FRONTEND
# ==============================================================================

# Base URL of your frontend — used to build links in emails
# (e.g. email verification, password reset)
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com
FRONTEND_URL='http://localhost:3000'


# ==============================================================================
# REDIS
# ==============================================================================

# Redis connection URL — used for caching, rate limiting, and task queues
# Local dev:      redis://localhost:6379
# Docker Compose: redis://redis:6379  (the service name)
# Production:     redis://:password@your-redis-host:6379
# With TLS:       rediss://:password@your-redis-host:6380
REDIS_URL='redis://localhost:6379'


# ==============================================================================
# AI / LLM PROVIDERS
# ==============================================================================

# ── Groq (active) ─────────────────────────────────────────────────────────────
# Fast LLM inference — currently used for resume optimisation
# 1. Go to: https://console.groq.com
# 2. Sign up / log in
# 3. Click "API Keys" → "Create API key"
# 4. Copy the key (starts with gsk_...)
# Free tier available — check limits at: https://console.groq.com/settings/limits
GROQ_API_KEY=gsk_your-api-key-here

# ── Gemini (optional — uncomment to enable) ───────────────────────────────────
# 1. Go to: https://aistudio.google.com/app/apikey
# 2. Click "Create API key"
# 3. Copy the key and uncomment the line below
# GEMINI_API_KEY=your-gemini-key-here

# ── OpenAI (optional — uncomment to enable) ───────────────────────────────────
# 1. Go to: https://platform.openai.com/api-keys
# 2. Click "Create new secret key"
# 3. Copy the key (starts with sk-...) and uncomment the line below
# OPENAI_API_KEY=sk-your-openai-key-here

# ── ANTHROPIC (optional — uncomment to enable) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-value-here



# ==============================================================================
# CORS — Cross-Origin Resource Sharing
# ==============================================================================

# Comma-separated list of origins allowed to call your API
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com
# Multiple:    http://localhost:3000,https://your-domain.com
# ⚠️  Never use * in production — always specify exact origins
ALLOWED_ORIGINS='http://localhost:3000'


# ==============================================================================
# STRIPE PAYMENT GATEWAY
# Docs: https://stripe.com/docs  |  Dashboard: https://dashboard.stripe.com
# ==============================================================================

# ------------------------------------------------------------------------------
# API KEYS
# Get from: https://dashboard.stripe.com/test/apikeys
#
# ⚠️  Always use TEST keys (sk_test_ / pk_test_) for local development.
#     NEVER commit real keys to git.
#
# Secret key  → "Secret key" section → click "Reveal test key"
# Publishable → visible immediately, no reveal needed
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE


# ------------------------------------------------------------------------------
# WEBHOOK SECRET
# Required to verify that incoming webhook events are genuinely from Stripe.
#
# Option A — Local dev (Stripe CLI):
#   1. Install Stripe CLI: https://stripe.com/docs/stripe-cli
#   2. Run: stripe login
#   3. Run: stripe listen --forward-to localhost:8000/webhooks/stripe/
#   4. Copy the printed whsec_... value here
#
# Option B — Production (Stripe Dashboard):
#   1. Dashboard → Developers → Webhooks → Add endpoint
#   2. URL: https://your-domain.com/webhooks/stripe/
#   3. Select events:
#        • checkout.session.completed
#        • customer.subscription.updated
#        • customer.subscription.deleted
#        • invoice.payment_failed
#   4. Save → click your endpoint → Signing secret → Reveal → copy here
# ------------------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE


# ------------------------------------------------------------------------------
# PRICE IDs  (generated by running: python app/services/stripe_setup.py)
#
# HOW TO GENERATE (first-time setup):
#   1. Fill in STRIPE_SECRET_KEY above
#   2. cd backend
#   3. source venv/bin/activate
#   4. python app/services/stripe_setup.py
#   5. Copy the printed price_... IDs into your .env
#
# ⚠️  Run stripe_setup.py ONCE per environment (sandbox + production separately).
#     Running it again creates duplicate products in Stripe.
#
# HOW TO CHANGE PRICES IN THE FUTURE:
#   Stripe prices are immutable once created — you cannot edit the amount.
#   To update pricing:
#   1. Go to: https://dashboard.stripe.com/test/products
#   2. Open "Resume Optimizer Pro" → click "Add another price"
#   3. Set the new amount and save
#   4. Copy the new price_... ID and replace the value below
#   5. Archive the old price in the dashboard so it no longer appears
#      (Products → your price → "..." menu → Archive)
#
# CURRENT PRICING (set in stripe_setup.py):
#   Pro Monthly  →  $9.99  / month
#   Pro Yearly   →  $79.99 / year  (~33% saving vs monthly)
#
# To change the default amounts, edit stripe_setup.py before first run:
#   unit_amount=999   # in cents → $9.99
#   unit_amount=7999  # in cents → $79.99
# ------------------------------------------------------------------------------
STRIPE_PRICE_ID_PRO_MONTHLY=price_YOUR_MONTHLY_PRICE_ID
STRIPE_PRICE_ID_PRO_YEARLY=price_YOUR_YEARLY_PRICE_ID